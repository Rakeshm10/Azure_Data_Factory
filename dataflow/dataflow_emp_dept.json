{
	"name": "dataflow_emp_dept",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "daynamic_sql_tables",
						"type": "DatasetReference"
					},
					"name": "employee"
				},
				{
					"dataset": {
						"referenceName": "daynamic_sql_tables",
						"type": "DatasetReference"
					},
					"name": "department"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "daynamic_sql_tables",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookupdeptemp"
				},
				{
					"name": "select"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          emp_id as integer,",
				"          emp_name as string,",
				"          email as string,",
				"          salary as integer,",
				"          dept_id as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> employee",
				"source(output(",
				"          dept_id as integer,",
				"          dept_name as string,",
				"          location as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> department",
				"employee, department lookup(employee@dept_id == department@dept_id,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookupdeptemp",
				"lookupdeptemp select(mapColumn(",
				"          emp_id,",
				"          emp_name,",
				"          email,",
				"          salary,",
				"          dept_id = department@dept_id,",
				"          dept_name,",
				"          location",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select",
				"select derive(dept_id = iif(isNull(dept_id), 22, dept_id),",
				"          dept_name = iif(isNull(dept_id), 'finance', dept_name),",
				"          location = iif(isNull(dept_id), 'bangalore', location)) ~> derivedColumn1",
				"derivedColumn1 alterRow(upsertIf(1==1)) ~> alterRow1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['emp_id'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          emp_id,",
				"          emp_name,",
				"          email,",
				"          salary,",
				"          dept_id,",
				"          dept_name,",
				"          location",
				"     )) ~> sink1"
			]
		}
	}
}