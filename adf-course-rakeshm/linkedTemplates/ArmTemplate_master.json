{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-course-rakeshm"
		},
		"AzureDL_Connection_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDL_Connection'"
		},
		"AzureSqlDatabase_connection_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase_connection'"
		},
		"AzureDL_Connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageadfrakesh1005.dfs.core.windows.net/"
		},
		"AzureSqlDatabase_connection_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "dfadvanceserver.database.windows.net"
		},
		"AzureSqlDatabase_connection_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "df-db"
		},
		"AzureSqlDatabase_connection_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "rakesh"
		},
		"Git_connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"Rest_API_Connection_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": " https://pokeapi.co/api/v2/pokemon"
		},
		"trigger2_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/a2688eea-3379-4c1a-a78c-d522a44487ef/resourceGroups/rg-adf-course/providers/Microsoft.Storage/storageAccounts/storageadfrakesh1005"
		},
		"trigger_storage_event_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/a2688eea-3379-4c1a-a78c-d522a44487ef/resourceGroups/rg-adf-course/providers/Microsoft.Storage/storageAccounts/storageadfrakesh1005"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-course-rakeshm_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDL_Connection_accountKey": {
						"value": "[parameters('AzureDL_Connection_accountKey')]"
					},
					"AzureSqlDatabase_connection_password": {
						"value": "[parameters('AzureSqlDatabase_connection_password')]"
					},
					"AzureDL_Connection_properties_typeProperties_url": {
						"value": "[parameters('AzureDL_Connection_properties_typeProperties_url')]"
					},
					"AzureSqlDatabase_connection_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase_connection_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase_connection_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase_connection_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase_connection_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase_connection_properties_typeProperties_userName')]"
					},
					"Git_connection_properties_typeProperties_url": {
						"value": "[parameters('Git_connection_properties_typeProperties_url')]"
					},
					"Rest_API_Connection_properties_typeProperties_url": {
						"value": "[parameters('Rest_API_Connection_properties_typeProperties_url')]"
					},
					"trigger2_properties_typeProperties_scope": {
						"value": "[parameters('trigger2_properties_typeProperties_scope')]"
					},
					"trigger_storage_event_properties_typeProperties_scope": {
						"value": "[parameters('trigger_storage_event_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-course-rakeshm_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-course-rakeshm_ArmTemplate_0')]"
			]
		},
		{
			"name": "adf-course-rakeshm_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-course-rakeshm_ArmTemplate_1')]"
			]
		}
	]
}